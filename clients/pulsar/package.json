{
  "name": "glls-client",
  "main": "./src/main",
  "version": "0.1.0",
  "description": "Client Pulsar per gl-ls (language server degli study.yml di granulation-studies)",
  "keywords": ["language-server", "granular", "yaml"],
  "repository": "https://github.com/DMGiulioRomano/gl-ls",
  "license": "MIT",
  "engines": {
    "atom": ">=1.0.0 <2.0.0"
  },
  "configSchema": {
    "serverPath": {
      "type": "string",
      "default": "glls",
      "title": "Percorso dell'eseguibile glls",
      "description": "Es. /percorso/a/gl-ls/.venv/bin/glls"
    }
  },
  "dependencies": {
    "atom-languageclient": "^1.16.1"
  },
  "enhancedScopes": ["source.yaml"],
  "consumedServices": {
    "linter-indie": {
      "versions": { "2.0.0": "consumeLinterV2" }
    },
    "datatip": {
      "versions": { "0.1.0": "consumeDatatip" }
    }
  },
  "providedServices": {
    "autocomplete.provider": {
      "versions": { "4.0.0": "provideAutocomplete" }
    },
    "code-actions": {
      "versions": { "0.1.0": "provideCodeActions" }
    },
    "definitions": {
      "versions": { "0.1.0": "provideDefinitions" }
    },
    "find-references": {
      "versions": { "0.1.0": "provideFindReferences" }
    },
    "outline-view": {
      "versions": { "0.1.0": "provideOutlines" }
    }
  }
}
